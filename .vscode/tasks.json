{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Frontend Dev",
            "type": "shell",
            "command": "npm run dev",
            "options": {
                "cwd": "${workspaceFolder}/frontend"
            },
            "presentation": {
                "panel": "new",
                "group": "dev"
            }
        },
        {
            "label": "Backend Dev",
            "type": "shell",
            "command": "npm run dev",
            "options": {
                "cwd": "${workspaceFolder}/backend"
            },
            "presentation": {
                "panel": "new",
                "group": "dev"
            }
        },
        {
            "label": "Start All",
            "dependsOn": [
                "Frontend Dev",
                "Backend Dev"
            ],
            "dependsOrder": "parallel",
            "runOptions": {
                "runOn": "folderOpen"
            }
        }
    ]
}
